# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-datastore
# Load Order: 90 (loaded after all defaults, overrides everything except 99-local.env)
#
# This file contains project-specific configuration that overrides defaults from earlier
# env files. Only settings that differ from the defaults need to be specified here.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Custom Go version for this project (overrides core defaults if needed)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider Selection (override: use codecov instead of internal)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (matches codecov.yml ignore paths + standard exclusions)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,docs/,example/,examples/,mocks/,test/,testing/,vendor/,testdata/

# ================================================================================================
# 🛡️ SECURITY CVE EXCLUSIONS
# ================================================================================================

# Nancy CVE Exclusions (known acceptable vulnerabilities)
NANCY_EXCLUDES=CVE-2026-24051,CVE-2026-34986,CVE-2026-33815,CVE-2026-39883

# Govulncheck/Magex CVE Exclusions (consistency with Nancy)
MAGE_X_CVE_EXCLUDES=CVE-2026-24051,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39883
